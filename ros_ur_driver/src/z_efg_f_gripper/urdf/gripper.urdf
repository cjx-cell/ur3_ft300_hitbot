<?xml version="1.0"?>
<robot name="z_efg_f_gripper">
  <!-- 根连杆：带唯一前缀z_efg_f_，无命名冲突 -->
  <link name="z_efg_f_base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://z_efg_f_gripper/dae/base_link.dae" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://z_efg_f_gripper/dae/base_link.dae" scale="1 1 1"/>
      </geometry>
    </collision>
    <inertial>  <!-- 修正：去掉多余的< -->
      <mass value="1.2"/>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <inertia ixx="0.005" ixy="0.0" ixz="0.0" iyy="0.005" iyz="0.0" izz="0.008"/>  <!-- 修正：去掉多余的< -->
    </inertial> <!-- 修正：闭合标签正确 -->
  </link>

  <!-- 左手指连杆：带前缀 -->
  <link name="z_efg_f_finger_left_link">
    <visual>
      <origin xyz="-0.04225 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://z_efg_f_gripper/dae/link_finger_left.dae" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="-0.04225 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://z_efg_f_gripper/dae/link_finger_left.dae" scale="1 1 1"/>
      </geometry>
    </collision>
    <inertial>  <!-- 修正：去掉多余的< -->
      <mass value="0.3"/>
      <origin xyz="-0.04225 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.0015"/>  <!-- 修正：去掉多余的< -->
    </inertial> <!-- 修正：闭合标签正确 -->
  </link>

  <!-- 右手指连杆：带前缀 -->
  <link name="z_efg_f_finger_right_link">
    <visual>
      <origin xyz="-0.04225 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://z_efg_f_gripper/dae/link_finger_right.dae" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="-0.04225 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://z_efg_f_gripper/dae/link_finger_right.dae" scale="1 1 1"/>
      </geometry>
    </collision>
    <inertial>  <!-- 修正：去掉多余的< -->
      <mass value="0.3"/>
      <origin xyz="-0.04225 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.0015"/>  <!-- 修正：去掉多余的< -->
    </inertial> <!-- 修正：闭合标签正确 -->
  </link>

  <!-- 左手指关节：带前缀 -->
  <joint name="z_efg_f_finger_left_joint" type="prismatic">
    <parent link="z_efg_f_base_link"/>
    <child link="z_efg_f_finger_left_link"/>
    <origin xyz="-0.04225 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.01" upper="0.01" effort="5" velocity="0.1"/>
  </joint>

  <!-- 右手指关节：带前缀 -->
  <joint name="z_efg_f_finger_right_joint" type="prismatic">
    <parent link="z_efg_f_base_link"/>
    <child link="z_efg_f_finger_right_link"/>
    <origin xyz="-0.04225 0 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-0.01" upper="0.01" effort="5" velocity="0.1"/>
  </joint>
</robot>
