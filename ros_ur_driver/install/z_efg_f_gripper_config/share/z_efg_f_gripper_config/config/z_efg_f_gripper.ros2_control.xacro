<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:macro name="z_efg_f_gripper_ros2_control" params="name initial_positions_file prefix">
        <!-- 关键修改：1. 改用双引号 2. 拆分默认值，避免嵌套字典的语法问题 -->
        <xacro:property name="yaml_data" value="${xacro.load_yaml(initial_positions_file)}"/>
        
        <!-- 先判断initial_positions键是否存在，不存在则手动定义默认值 -->
        <xacro:if value="${'initial_positions' in yaml_data}">
            <xacro:property name="initial_positions" value="${yaml_data['initial_positions']}"/>
        </xacro:if>
        <xacro:unless value="${'initial_positions' in yaml_data}">
            <xacro:property name="initial_positions">
                <xacro:dict>
                    <xacro:item key="finger_left_joint" value="0"/>
                    <xacro:item key="finger_right_joint" value="0"/>
                </xacro:dict>
            </xacro:property>
        </xacro:unless>

        <ros2_control name="${name}" type="system">
            <hardware>
                <plugin>fake_components/GenericSystem</plugin>
            </hardware>
            <joint name="${prefix}z_efg_f_finger_left_joint">
                <command_interface name="position"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['finger_left_joint'] if 'finger_left_joint' in initial_positions else 0}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="${prefix}z_efg_f_finger_right_joint">
                <command_interface name="position"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['finger_right_joint'] if 'finger_right_joint' in initial_positions else 0}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
        </ros2_control>
    </xacro:macro>
</robot>
