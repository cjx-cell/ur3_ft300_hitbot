    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://robotiq_ft_sensor/meshes/visual/robotiq_ft300.STL"/>
      </geometry>
      <material name="Robotiq-Black">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://robotiq_ft_sensor/meshes/collision/robotiq_ft300.STL"/>
      </geometry>
    </collision>
  </link>
  <!-- Link representing the FT300 mounting plate -->
  <link name="ft300_mounting_plate">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://robotiq_ft_sensor/meshes/visual/mountings/robotiq_ft300-G-062-COUPLING_G-50-4M6-1D6_20181119.STL"/>
      </geometry>
      <material name="Robotiq-Grey">
        <color rgba="0.4 0.4 0.4 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://robotiq_ft_sensor/meshes/collision/mountings/robotiq_ft300-G-062-COUPLING_G-50-4M6-1D6_20181119.STL"/>
      </geometry>
    </collision>
  </link>
  <!-- Connect force sensor with mounting/coupling plate -->
  <!-- 仅修改此处：关节名从 ${prefix}ft300_mounting_plate 改为 ${prefix}ft300_mounting_joint，避免与同名Link冲突 -->
  <joint name="ft300_mounting_joint" type="fixed">
    <origin rpy="0 3.141592653589793 0" xyz="0 0 0.0415"/>
    <parent link="ft300_mounting_plate"/>
    <child link="ft300_sensor"/>
  </joint>
  <!-- FORCE REFERENCE FRAME _______________________________________________________________________________
    As specified in the documentation:
    - The Z axis passes through the center of the depression with positive direction in the tool direction.
    - The X axis traces a symmetric line centered on the connector; the positive direction
        points the opposite way away from the connector.
    - The Y axis uses the right hand thumb rule according to X-Z. -->
  <joint name="measurment_joint" type="fixed">
    <origin rpy="0 3.141592653589793 -1.5707963267948966" xyz="0 0 0"/>
    <parent link="ft300_sensor"/>
    <child link="robotiq_ft_frame_id"/>
  </joint>
  <link name="robotiq_ft_frame_id"/>
  <!-- 根连杆：带唯一前缀z_efg_f_，无命名冲突 -->
  <link name="z_efg_f_base_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://z_efg_f_gripper/dae/base_link.dae" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://z_efg_f_gripper/dae/base_link.dae" scale="1 1 1"/>
      </geometry>
    </collision>
    <inertial>
      <!-- 修正：去掉多余的< -->
      <mass value="1.2"/>
      <origin rpy="0 0 0" xyz="0 0 0.05"/>
      <inertia ixx="0.005" ixy="0.0" ixz="0.0" iyy="0.005" iyz="0.0" izz="0.008"/>
      <!-- 修正：去掉多余的< -->
    </inertial>
    <!-- 修正：闭合标签正确 -->
  </link>
  <!-- 左手指连杆：带前缀 -->
  <link name="z_efg_f_finger_left_link">
    <visual>
      <origin rpy="0 0 0" xyz="-0.04225 0 0"/>
      <geometry>
        <mesh filename="package://z_efg_f_gripper/dae/link_finger_left.dae" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="-0.04225 0 0"/>
      <geometry>
        <mesh filename="package://z_efg_f_gripper/dae/link_finger_left.dae" scale="1 1 1"/>
      </geometry>
    </collision>
    <inertial>
      <!-- 修正：去掉多余的< -->
      <mass value="0.3"/>
      <origin rpy="0 0 0" xyz="-0.04225 0 0"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.0015"/>
      <!-- 修正：去掉多余的< -->
    </inertial>
    <!-- 修正：闭合标签正确 -->
  </link>
  <!-- 右手指连杆：带前缀 -->
  <link name="z_efg_f_finger_right_link">
    <visual>
      <origin rpy="0 0 0" xyz="-0.04225 0 0"/>
      <geometry>
        <mesh filename="package://z_efg_f_gripper/dae/link_finger_right.dae" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="-0.04225 0 0"/>
      <geometry>
        <mesh filename="package://z_efg_f_gripper/dae/link_finger_right.dae" scale="1 1 1"/>
      </geometry>
    </collision>
    <inertial>
      <!-- 修正：去掉多余的< -->
      <mass value="0.3"/>
      <origin rpy="0 0 0" xyz="-0.04225 0 0"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.0015"/>
      <!-- 修正：去掉多余的< -->
    </inertial>
    <!-- 修正：闭合标签正确 -->
  </link>
  <!-- 左手指关节：带前缀 -->
  <joint name="z_efg_f_finger_left_joint" type="prismatic">
    <parent link="z_efg_f_base_link"/>
    <child link="z_efg_f_finger_left_link"/>
    <origin rpy="0 0 0" xyz="-0.04225 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="5" lower="-0.01" upper="0.01" velocity="0.1"/>
  </joint>
  <!-- 右手指关节：带前缀 -->
  <joint name="z_efg_f_finger_right_joint" type="prismatic">
    <parent link="z_efg_f_base_link"/>
    <child link="z_efg_f_finger_right_link"/>
    <origin rpy="0 0 0" xyz="-0.04225 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit effort="5" lower="-0.01" upper="0.01" velocity="0.1"/>
  </joint>
  <!-- Import control_xacro -->
  <!--<xacro:include filename="z_efg_f_gripper.ros2_control.xacro" />


    <xacro:z_efg_f_gripper_ros2_control name="FakeSystem" initial_positions_file="$(arg initial_positions_file)"/>-->
  <!-- 3. 挂载夹爪到FT300（指向带前缀的夹爪根link：z_efg_f_base_link） -->
  <joint name="ft300_to_gripper_joint" type="fixed">
    <parent link="robotiq_ft_frame_id"/>
    <!-- FT300输出端 -->
    <child link="z_efg_f_base_link"/>
    <!-- 夹爪根link（带前缀，无冲突） -->
    <origin rpy="0 -1.57 0" xyz="0 0 0.042"/>
    <!-- 偏移按需调整 -->
  </joint>
</robot>
